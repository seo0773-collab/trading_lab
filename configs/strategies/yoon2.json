{
  "version": "yoon2",
  "interval": "1d",
  "period": "max",
  "fast_len": 12,
  "slow_len": 26,
  "signal_len": 9,
  "kalman_q": 0.01,
  "kalman_r": 0.10,
  "kalman_base": "MACD Line",
  "direction": "long",
  "entry_trigger": "delta_turn",
  "atr_len": 14,
  "confirm_bars": 2,
  "min_hist_gap_atr": 0.0,
  "macd_zero_filter": true,
  "atr_stop_mult": 0.0,
  "max_hold_bars": 0,
  "tp_enabled": false,
  "tp_quantiles": [0.33, 0.66, 0.90],
  "tp_fractions": [0.3333, 0.3333, 0.3334],
  "tp_atr_scale": 30.0,
  "tp_min_samples": 30,
  "costs": {
    "fee_bps_per_side": 5.0,
    "slippage_bps": 5.0
  },
  "execution": "next_open",
  "train_frac": 0.6,
  "validation_frac": 0.2,
  "synthetic_bars": 4000,
  "seed": 7,
  "dashboard": {
    "default_indicators": ["kal_macd", "kal_signal", "kal_hist", "kal_hist_delta"],
    "indicator_labels": {
      "kal_macd": "Kalman MACD",
      "kal_signal": "Kalman Signal",
      "kal_hist": "Kalman Histogram",
      "kal_hist_delta": "Kalman Hist Delta",
      "atr": "ATR"
    }
  },
  "tunables": [
    {"name": "kalman_base", "label": "칼만 기준선", "type": "select",
     "options": ["MACD Line", "Fast/Slow EMA"], "default": "MACD Line"},
    {"name": "direction", "label": "방향", "type": "select",
     "options": ["both", "long", "short"], "default": "long"},
    {"name": "entry_trigger", "label": "진입 트리거", "type": "select",
     "options": ["delta_turn", "cross"], "default": "delta_turn"},
    {"name": "kalman_q", "label": "kalman_q (반응성)", "type": "number",
     "min": 0.001, "max": 0.5, "step": 0.001, "default": 0.01},
    {"name": "kalman_r", "label": "kalman_r (평활도)", "type": "number",
     "min": 0.001, "max": 2.0, "step": 0.01, "default": 0.10},
    {"name": "confirm_bars", "label": "델타 전환 확인봉", "type": "int",
     "min": 1, "max": 10, "step": 1, "default": 2},
    {"name": "min_hist_gap_atr", "label": "최소 히스토 격차(ATR배수)",
     "type": "number", "min": 0.0, "max": 2.0, "step": 0.05, "default": 0.0},
    {"name": "macd_zero_filter", "label": "kalMACD 0선 추세필터",
     "type": "select", "options": [false, true], "default": true},
    {"name": "atr_stop_mult", "label": "ATR 손절배수(0=off)", "type": "number",
     "min": 0.0, "max": 6.0, "step": 0.5, "default": 0.0},
    {"name": "max_hold_bars", "label": "최대 보유봉(0=off)", "type": "int",
     "min": 0, "max": 250, "step": 1, "default": 0},
    {"name": "tp_enabled", "label": "분포 익절 사다리(부분청산)", "type": "select",
     "options": [false, true], "default": false},
    {"name": "tp_atr_scale", "label": "익절 ATR 스케일", "type": "number",
     "min": 1.0, "max": 100.0, "step": 1.0, "default": 30.0}
  ]
}
